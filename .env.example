ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://automl:automl@localhost:55432/automl
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_MINUTES=1440
JWT_REFRESH_ROTATION_HOURS=168
SIMPLE_AUTH_ENABLED=true
OBJECT_STORE_TYPE=minio
OBJECT_STORE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORE_BUCKET=automl
OBJECT_STORE_ACCESS_KEY=automl
OBJECT_STORE_SECRET_KEY=change-me
LOCAL_OBJECT_STORE_PATH=.automl_object_store
DATASET_CACHE_SIZE_GB=5
GPU_ENABLED=true
MAX_CLUSTER_CPU_PERCENT=70
MAX_NODE_AVAILABLE_FRACTION_PER_JOB=1.0
MAX_CONCURRENT_JOBS=2
MLFLOW_TRACKING_URI=http://mlflow:5000
TRAINING_NAMESPACE=automl
TRAINING_IMAGE=automl-training:metrics-v2
TRAINING_SERVICE_ACCOUNT=default
INFERENCE_IMAGE=automl-inference:local
INFERENCE_SERVICE_ACCOUNT=default
INFERENCE_SERVICE_TYPE=NodePort
TRAINING_ACTIVE_DEADLINE_SECONDS=21600
TRAINING_MAX_ACTIVE_DEADLINE_SECONDS=86400
TRAINING_DEADLINE_MULTIPLIER=6
