ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://automl:automl@localhost:55432/automl
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_MINUTES=1440
JWT_REFRESH_ROTATION_HOURS=168
SIMPLE_AUTH_ENABLED=true
PUBLIC_APP_URL=http://localhost:8080
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
SMTP_USE_SSL=false
OBJECT_STORE_TYPE=minio
OBJECT_STORE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORE_BUCKET=automl
OBJECT_STORE_ACCESS_KEY=automl
OBJECT_STORE_SECRET_KEY=change-me
LOCAL_OBJECT_STORE_PATH=.automl_object_store
DATASET_CACHE_SIZE_GB=5
DATASET_CACHE_PVC_NAME=
GPU_ENABLED=false
CLUSTER_OBSERVER_ENABLED=false
NVIDIA_GPU_RESOURCE=nvidia.com/gpu
INTEL_GPU_RESOURCE=gpu.intel.com/xe
MAX_CONCURRENT_JOBS=2
MLFLOW_TRACKING_URI=http://mlflow:5000
TRAINING_NAMESPACE=automl
TRAINING_IMAGE=docker.io/maponyacharles/sceptreai:training-cpu-0.1.4
TRAINING_IMAGE_NVIDIA=docker.io/maponyacharles/sceptreai:training-nvidia-0.1.4
TRAINING_IMAGE_INTEL=docker.io/maponyacharles/sceptreai:training-intel-0.1.4
TRAINING_IMAGE_PULL_POLICY=IfNotPresent
WORKLOAD_IMAGE_PULL_SECRETS=
TRAINING_SERVICE_ACCOUNT=default
TRAINING_CPU_REQUEST_CORES=1
TRAINING_CPU_LIMIT_CORES=2
TRAINING_MEMORY_REQUEST_MB=1024
TRAINING_MEMORY_LIMIT_MB=4096
TRAINING_PRIORITY_CLASS_NAME=
TRAINING_JOB_TTL_SECONDS=300
DATABASE_SECRET_NAME=automl-platform-secrets
DATABASE_SECRET_KEY=DATABASE_URL
OBJECT_STORE_SECRET_NAME=automl-minio-credentials
OBJECT_STORE_ACCESS_KEY_SECRET_KEY=MINIO_ROOT_USER
OBJECT_STORE_SECRET_KEY_SECRET_KEY=MINIO_ROOT_PASSWORD
INFERENCE_IMAGE=docker.io/maponyacharles/sceptreai:inference-0.1.4
INFERENCE_IMAGE_PULL_POLICY=IfNotPresent
INFERENCE_SERVICE_ACCOUNT=default
INFERENCE_SERVICE_TYPE=ClusterIP
INFERENCE_EXTERNAL_HOST=
INFERENCE_EXTERNAL_SCHEME=http
INFERENCE_INGRESS_ENABLED=false
INFERENCE_INGRESS_CLASS_NAME=
INFERENCE_INGRESS_HOST_TEMPLATE=
INFERENCE_INGRESS_TLS_SECRET_NAME=
TRAINING_ACTIVE_DEADLINE_SECONDS=21600
TRAINING_MAX_ACTIVE_DEADLINE_SECONDS=86400
TRAINING_DEADLINE_MULTIPLIER=6
