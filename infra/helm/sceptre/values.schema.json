{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "imageRegistry": {"type": "string"},
        "imagePullSecrets": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "image": {
          "type": "object",
          "properties": {
            "tag": {"type": "string"},
            "digest": {"type": "string"}
          }
        }
      }
    },
    "seaweedfs": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "image": {
          "type": "object",
          "properties": {
            "tag": {"type": "string"},
            "digest": {"type": "string"}
          }
        },
        "bucket": {"type": "string", "minLength": 1},
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "size": {"type": "string", "minLength": 1}
          }
        }
      },
      "required": ["enabled"]
    },
    "mlflow": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "workers": {"type": "integer", "minimum": 1}
      }
    },
    "training": {
      "type": "object",
      "properties": {
        "maxConcurrentJobs": {"type": "integer", "minimum": 1},
        "imagePullPolicy": {"enum": ["Always", "IfNotPresent", "Never"]},
        "cpu": {
          "type": "object",
          "properties": {
            "requestCores": {"type": "number", "minimum": 0.25},
            "limitCores": {"type": "number", "minimum": 0.25},
            "memoryRequestMb": {"type": "integer", "minimum": 256},
            "memoryLimitMb": {"type": "integer", "minimum": 256}
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "mode": {"enum": ["ephemeral", "shared-pvc"]},
            "emptyDirSizeGb": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "inference": {
      "type": "object",
      "properties": {
        "serviceType": {"enum": ["ClusterIP", "NodePort", "LoadBalancer"]},
        "externalScheme": {"enum": ["http", "https"]}
      }
    }
  }
}
